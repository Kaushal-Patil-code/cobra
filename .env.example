# ============================================================
# COBRA — environment configuration
# Copy to .env and fill in real values. .env is gitignored.
#   cp .env.example .env
# ============================================================

# ---- App ----
APP_NAME=cobra
ENV=development            # development | production | testing
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ---- Supabase Postgres (direct connection) ----
# Supabase dashboard → Project Settings → Database → Connection string (URI).
#  - Direct (port 5432): long-lived connections; best with this app's pool.
#  - Transaction pooler (port 6543, pgBouncer): for serverless/high fan-out.
#    Detected automatically — prepared statements are disabled for it.
# Always include sslmode=require (Supabase mandates TLS).
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Alternative: leave DATABASE_URL blank and supply the parts instead.
# DB_HOST=db.[PROJECT-REF].supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=
# DB_SSLMODE=require

# ---- Connection-pool tuning ----
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_POOL_MAX_IDLE=600
DB_CONNECT_TIMEOUT=10
DB_STATEMENT_TIMEOUT_MS=30000

# Prepared statements: leave defaults for direct connections. Set true only if
# you hit "prepared statement already exists" behind a pooler we didn't detect.
# DB_DISABLE_PREPARED_STATEMENTS=false
# DB_PREPARE_THRESHOLD=5

# ---- Fyers broker auto-login (TOTP) ----
# Credentials live here; the issued access/refresh tokens are persisted in the
# fyers_tokens DB table (not on disk).
FYERS_APP_ID=
FYERS_SECRET_KEY=
FYERS_REDIRECT_URL=
FYERS_USERNAME=
FYERS_PIN=
FYERS_TOTP_SECRET=
# Warm the token on server startup (single-flight across gunicorn workers).
# No-ops when the credentials above are unset. Set false to disable.
FYERS_AUTOLOGIN_ON_STARTUP=true
# Retry the whole TOTP login this many times (with this delay, seconds, between
# attempts) when an attempt fails — on top of the per-request network retries.
FYERS_LOGIN_MAX_ATTEMPTS=3
FYERS_LOGIN_RETRY_DELAY=5

# ---- Internal scheduler (self-driving cycle) ----
# Ticks run ONLY Mon–Fri 09:15–15:30 IST (cron-bounded; closed otherwise).
SCHEDULER_ENABLED=true
TICK_INTERVAL_MINUTES=3
TICK_STRIKECOUNT=10
TICK_WINDOW_MINUTES=15
# Pre-warm the Fyers token a couple minutes before the open so capture is live by 09:15.
PRELOGIN_HOUR=9
PRELOGIN_MINUTE=13

# ---- Render keep-alive ----
# A free Render web service spins down after ~15 min idle; the app pings its OWN
# public /health every N minutes to stay awake (so the 09:13 pre-login can fire).
# Set KEEPALIVE_URL MANUALLY to your deployed base URL, e.g.
#   KEEPALIVE_URL=https://cobra-xxxx.onrender.com
# (It wins over RENDER_EXTERNAL_URL, which Render injects automatically.)
# Leave blank to disable keep-alive.
KEEPALIVE_URL=
KEEPALIVE_ENABLED=true
KEEPALIVE_INTERVAL_MINUTES=7
# RENDER_EXTERNAL_URL is set automatically on Render; only override for local tests.
# RENDER_EXTERNAL_URL=
